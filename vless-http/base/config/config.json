{
  "log": {
    "loglevel": "info"
  },
  "inbounds": [
    {
      "tag": "vless-http",
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "b831381d-6324-4d53-ad4f-8cda48b30811",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "serverName": "vless-httpx.outi.ir",
          "alpn": [],
          "minVersion": "1.2",
          "certificates": [
            {
              "certificateFile": "/etc/xray/tls/tls.crt",
              "keyFile": "/etc/xray/tls/tls.key"
            }
          ]
        },
        "tcpSettings": {
          "header": {
            "type": "http",
            "request": {
              "path": ["/vless"],
              "headers": {
                "User-Agent": ["Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/101.0.4951.67 Safari/537.36"]
              }
            }
          }
        }
      },
      "sniffing": {
        "enabled": false
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "inboundTag": ["vless-http"],
        "outboundTag": "direct"
      }
    ]
  }
}
