{
  "log": {
    "loglevel": "info"
  },
  "inbounds": [
    {
      "tag": "vless-http",
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "b831381d-6324-4d53-ad4f-8cda48b30811",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "www.google.com:443",
          "xver": 0,
          "serverNames": [
            "vless-httpx.outi.ir",
            "www.google.com",
            "www.cloudflare.com"
          ],
          "privateKey": "CO9QUYymPuKdGalikn6HqDREi845ATRB5qBS_anpiWM",
          "shortIds": [
            "",
            "6ba85179e30d4fc2"
          ]
        },
        "xhttpSettings": {
          "mode": "stream-one",
          "path": "/vless",
          "noGRPCHeader": true,
          "xmux": {
            "maxConcurrency": "6",
            "hKeepAlivePeriod": 12
          },
          "headers": {
            "User-Agent": "Mozilla/5.0(Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/101.0.4951.67 Safari/537.36"
          }
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "inboundTag": ["vless-http"],
        "outboundTag": "direct"
      }
    ]
  }
}
